# Copy to `.env` in this directory and fill in values. Do not commit `.env`.

# HTTP port (Render sets PORT automatically; default 3000 locally)
PORT=3000

# PostgreSQL connection string (required for deck catalog and create routes)
DATABASE_URL=

# Optional: max connections in the pg pool (default 10; use 2–5 on Render free tier)
# PG_POOL_MAX=2

# Force SSL when not encoded in DATABASE_URL (Render: set PGSSL=true)
# PGSSL=true

# Optional: path to CA cert for verify-full / verify-ca (relative to app root or absolute)
# Local BYU example: PGSSLROOTCERT=byuicse-psql-cert.pem
# Render Secret File example: PGSSLROOTCERT=/etc/secrets/byuicse-psql-cert.pem

# --- Render.com deploy checklist ---
# 1. New Web Service → connect repo → Root Directory: Card Game API/card_game_api_site
# 2. Build: npm install   Start: npm start   Health check: /api/health
# 3. Environment: DATABASE_URL, PGSSL=true, PG_POOL_MAX=2
# 4. If DB needs a CA cert: Secret File + PGSSLROOTCERT path above
# 5. Smoke test: /api-demo.html → Fetch deck names → Create single pile
